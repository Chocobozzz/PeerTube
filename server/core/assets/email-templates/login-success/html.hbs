{{#> base title=(t "New login to your account")}}
  <p>
    {{{t "A new login to your account on {instanceName} was detected from a <strong>new device</strong>." instanceName=instanceName}}}
  </p>

  <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="margin: 16px 0;">
    <tr>
      <td style="padding: 6px 0; font-family: sans-serif; font-size: 14px;">
        <strong>{{t "Date"}}</strong>
      </td>
      <td style="padding: 6px 0; font-family: sans-serif; font-size: 14px;">{{date}}</td>
    </tr>
    {{#if ip}}
    <tr>
      <td style="padding: 6px 0; font-family: sans-serif; font-size: 14px;">
        <strong>{{t "IP address"}}</strong>
      </td>
      <td style="padding: 6px 0; font-family: sans-serif; font-size: 14px;">{{ip}}</td>
    </tr>
    {{/if}}
    {{#if location}}
    <tr>
      <td style="padding: 6px 0; font-family: sans-serif; font-size: 14px;">
        <strong>{{t "Approximate location"}}</strong>
      </td>
      <td style="padding: 6px 0; font-family: sans-serif; font-size: 14px;">{{location}}</td>
    </tr>
    {{/if}}
    {{#if device}}
    <tr>
      <td style="padding: 6px 0; font-family: sans-serif; font-size: 14px; vertical-align: top;">
        <strong>{{t "Browser / device"}}</strong>
      </td>
      <td style="padding: 6px 0; font-family: sans-serif; font-size: 14px;">{{device}}</td>
    </tr>
    {{/if}}
  </table>

  <p>
    {{t "If this was you, you can safely ignore this email. If you don't recognize this activity, we recommend changing your password as soon as possible."}}
  </p>
{{/base}}
